{
  "name": "@atlas-art/ui-react",
  "version": "0.1.12",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles/ui.css": "./dist/styles/ui.css",
    "./adapters/react-router": {
      "types": "./dist/adapters/react-router/index.d.ts",
      "import": "./dist/adapters/react-router/index.js",
      "require": "./dist/adapters/react-router/index.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && mkdir -p dist/styles && cp ../core/styles/ui.css dist/styles/ui.css",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "react-router": ">=7"
  },
  "peerDependenciesMeta": {
    "react-router": {
      "optional": true
    }
  },
  "dependencies": {
    "@atlas-art/ui-core": "^0.1.12",
    "class-variance-authority": "^0.7.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tsup": "^8.5.0",
    "typescript": "^5.9.3"
  }
}
